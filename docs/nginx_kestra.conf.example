server {
    listen 80;
    server_name kestra.letterscode.com;

    # Redirect HTTP to HTTPS (Certbot will create an HTTPS server block)
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl;
    server_name kestra.gratiosoft.com;

    # SSL config will be filled by Certbot; these are placeholders
    ssl_certificate /etc/letsencrypt/live/kestra.letterscode.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/kestra.letterscode.com/privkey.pem;

    client_max_body_size 50M;

    location / {
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_http_version 1.1;
        proxy_set_header Connection "";
        proxy_pass http://127.0.0.1:8080;
    }

    # Optional health endpoint passthrough
    location /health {
        proxy_pass http://127.0.0.1:8080/health;
        proxy_set_header Host $host;
    }
}

# If you use a separate management port (8081), add an internal-only block
# to allow local access or an authenticated route as needed.
