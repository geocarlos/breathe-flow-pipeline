[Unit]
Description=Kestra Docker Compose Stack
After=docker.service
Requires=docker.service

[Service]
Type=oneshot
RemainAfterExit=yes
WorkingDirectory=/opt/breathe-flow-pipeline
ExecStart=/usr/bin/docker-compose -f /opt/breathe-flow-pipeline/docker-compose.vps.yml up -d --remove-orphans
ExecStop=/usr/bin/docker-compose -f /opt/breathe-flow-pipeline/docker-compose.vps.yml down
TimeoutStartSec=300
TimeoutStopSec=300

[Install]
WantedBy=multi-user.target

# Copy this file to /etc/systemd/system/kestra-stack.service and run:
# sudo systemctl daemon-reload
# sudo systemctl enable --now kestra-stack.service
