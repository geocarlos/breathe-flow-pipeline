
# GCP project and credentials
GCP_PROJECT_ID=your-gcp-project-id
GCS_BUCKET_NAME=your-gcs-bucket-name
GOOGLE_APPLICATION_CREDENTIALS=/path/to/google_credentials.json

# BigQuery datasets
BQ_SOURCE_DATASET=openaq
BQ_DATASET=breathe_flow
BQ_TABLE=raw

# OpenAQ API key (optional — public endpoints work without one)
OPENAQ_API_KEY=

# Kestra UI admin credentials (admin user for other tooling)
KESTRA_ADMIN_USER=kestra@letterscode.com
KESTRA_ADMIN_PASSWORD=changeme

# Kestra UI basic auth (must be an email address)
KESTRA_BASIC_AUTH_USERNAME=kestra@letterscode.com
KESTRA_BASIC_AUTH_PASSWORD=changeme